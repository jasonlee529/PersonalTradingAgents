# 运行模式
DEPLOY_MODE=0
TEST_MODE=false

# 本地存储路径。这些目录默认被 Git 忽略。
DATA_DIR=./data
KNOWLEDGE_DIR=./data/knowledge
RAW_KNOWLEDGE_DIR=./data/knowledge/raw
WIKI_KNOWLEDGE_DIR=./data/knowledge/wiki
WIKI_KNOWLEDGE_DB_PATH=./data/knowledge/wiki/index.db
WIKI_SCHEMA_DIR=./data/knowledge/schema
DERIVED_KNOWLEDGE_DIR=./data/knowledge/derived
DERIVED_KNOWLEDGE_DB_PATH=./data/knowledge/derived/index.db
RUNTIME_CACHE_DIR=./data/cache
ANALYSIS_ARTIFACTS_DIR=./data/artifacts/analysis
CHECKPOINT_DIR=./data/db/checkpoints
CACHE_DB_PATH=./data/db/cache.db
PORTFOLIO_DB_PATH=./data/db/portfolio.db
ANALYSIS_DB_PATH=./data/db/analysis.db
HISTORICAL_DB_PATH=./data/db/historical.db
FUND_HOLDINGS_DB_PATH=./data/db/fund_holdings.db

# API 服务
API_HOST=127.0.0.1
API_PORT=8000

# 缓存时间，单位：秒
CACHE_TTL_QUOTES=300
CACHE_TTL_KLINE=3600
CACHE_TTL_NEWS=86400
CACHE_TTL_FUNDAMENTALS=604800
CACHE_TTL_INDICATORS=3600
CACHE_TTL_ANNOUNCEMENTS=86400
CACHE_TTL_RESEARCH_REPORTS=604800

# LLM 提供商和模型
OPENAI_QUICK_MODEL=
OPENAI_DEEP_MODEL=
DEEPSEEK_QUICK_MODEL=
DEEPSEEK_DEEP_MODEL=
ANTHROPIC_QUICK_MODEL=
ANTHROPIC_DEEP_MODEL=
GOOGLE_QUICK_MODEL=
GOOGLE_DEEP_MODEL=
AZURE_QUICK_MODEL=
AZURE_DEEP_MODEL=
XAI_QUICK_MODEL=
XAI_DEEP_MODEL=
QWEN_QUICK_MODEL=
QWEN_DEEP_MODEL=
QWEN_CN_QUICK_MODEL=
QWEN_CN_DEEP_MODEL=
GLM_QUICK_MODEL=
GLM_DEEP_MODEL=
GLM_CN_QUICK_MODEL=
GLM_CN_DEEP_MODEL=
MINIMAX_QUICK_MODEL=
MINIMAX_DEEP_MODEL=
MINIMAX_CN_QUICK_MODEL=
MINIMAX_CN_DEEP_MODEL=
OPENROUTER_QUICK_MODEL=
OPENROUTER_DEEP_MODEL=
KIMI_QUICK_MODEL=
KIMI_DEEP_MODEL=
OPENCODE_GO_QUICK_MODEL=
OPENCODE_GO_DEEP_MODEL=
OLLAMA_QUICK_MODEL=
OLLAMA_DEEP_MODEL=
LLAMACPP_QUICK_MODEL=
LLAMACPP_DEEP_MODEL=
LLM_TIMEOUT=600
ANALYSIS_TIMEOUT_SECONDS=3600

# API 密钥。只在本地 .env 中填写，不要提交。
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
KIMI_API_KEY=
OPENCODE_GO_API_KEY=
TUSHARE_API_KEY=

# Local OpenAI-compatible runtimes. Change these when using a server other
# than the default port.
OLLAMA_BASE_URL=http://localhost:11434/v1
LLAMACPP_BASE_URL=http://localhost:8080/v1

# 雪球配置。仅在提供 Cookie 时使用；Cookie 无效时会回退到其他新闻源。
XUEQIU_COOKIE=
XUEQIU_AUTO_COOKIE=true
XUEQIU_TIMEOUT=10

# Tushare 配置。用于获取基金持仓数据和涨停数据。
TUSHARE_API_KEY=
FUND_HOLDINGS_REFRESH_ENABLED=false
FUND_HOLDINGS_REFRESH_SCHEDULE=0 2 * * 1-5

# 调度和后台任务
SCHEDULER_ENABLED=false
ANALYSIS_SCHEDULE=0 9 * * 1-5
ANALYSIS_WORKER_ENABLED=true

# 功能开关
SECTOR_DISCOVERY_MOCK_MODE=false
QUALITY_GATE_ENABLED=false
SIGNAL_TOOLS_ENABLED=false
CHECKPOINT_ENABLED=false
WIKI_AUTO_ANALYSIS_ENABLED=false
AUTO_EMBEDDING_ENABLED=false

# 通知
NOTIFICATION_ENABLED=false
DAILY_DIRECTION_NOTIFICATION_ENABLED=false
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=
NOTIFICATION_REPORT_CHANNELS=
NOTIFICATION_ALERT_CHANNELS=
NOTIFICATION_SYSTEM_ERROR_CHANNELS=
